# API
JWT_SECRET=ваш_надёжный_секрет_из_64_символов_сгенерируйте_через_openssl_rand_-hex_32

# DB
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
DATABASE_URL=postgresql+asyncpg://app:secret@db:5432/app

# MinIO
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=media
# MINIO_ENDPOINT остаётся внутренним — не меняется
MINIO_ENDPOINT=http://minio:9000

# Redis (fan-out WebSocket между воркерами; без REDIS_URL — только in-memory)
REDIS_URL=redis://redis:6379/0

# Celery: периодическая отмена просроченных open-заданий
CELERY_CLEANUP_INTERVAL_SEC=300
JOB_OPEN_DEFAULT_HOURS=48